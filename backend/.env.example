# Get a free key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Local Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://admin:password@localhost:5432/support_agent

# RAG vector store (relative to backend/ when run locally)
CHROMA_DIR=./chroma_db

# Optional — falls back to in-memory dict if unset
# REDIS_URL=redis://localhost:6379

# Gemini model (default fine for most uses)
GEMINI_MODEL=gemini-2.5-flash

ENVIRONMENT=development
